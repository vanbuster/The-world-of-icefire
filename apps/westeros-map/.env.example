# Public app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTENT_SOURCE=mock

# Payload CMS
PAYLOAD_SECRET=replace-with-a-long-random-secret-before-deploy

# Local development defaults to SQLite when DATABASE_URI is not set.
SQLITE_DATABASE_URI=file:./payload-dev.db

# Optional PostgreSQL override for deployment or explicit local Postgres use.
# DATABASE_URI=postgres://westeros:westeros@localhost:5432/westeros_map

# Admin bootstrap seed values for local-only scripts.
PAYLOAD_ADMIN_EMAIL=admin@example.com
PAYLOAD_ADMIN_PASSWORD=replace-before-use
